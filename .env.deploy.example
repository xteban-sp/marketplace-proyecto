# Copia este archivo como .env en la VM (junto a docker-compose.prod.yml) y completa los valores.
# NO lo subas a GitHub.

# --- Dominio (solo para despliegue público con HTTPS) ---
# Tu dominio para que Caddy saque el certificado. Ej: mimarketplace.duckdns.org
SITE_ADDRESS=tudominio.duckdns.org
# La URL pública completa (con https://). Se usa en correos, pagos y CORS.
PUBLIC_URL=https://tudominio.duckdns.org
#
# Para correr SOLO en local (en tu PC), deja estas dos líneas comentadas:
# por defecto Caddy sirve en http://localhost y todo funciona sin dominio.

# Secret JWT compartido (mínimo 32 caracteres). Cámbialo por uno propio.
JWT_SECRET=cambia_esto_por_un_secreto_largo_de_minimo_32_caracteres

# Admin inicial (se crea al arrancar auth-service)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ponuna_clave_fuerte

# Correo para verificación de cuenta (opcional; si lo dejas vacío, no se exige verificación)
MAIL_USERNAME=
MAIL_PASSWORD=

# Mercado Pago (opcional; vacío = modo simulado)
MERCADOPAGO_ACCESS_TOKEN=
