# Copia este archivo a `.env` y rellena los valores. `.env` NO se versiona.

# URL del API Gateway. El frontend SIEMPRE habla con el gateway, nunca con los servicios sueltos.
# En desarrollo: http://localhost:8080
# En producción: déjalo vacío para usar el mismo origen (Caddy proxea /api -> gateway).
VITE_API_URL=http://localhost:8080

# Cloudinary (subida de fotos de productos). Crea una cuenta gratis y un "unsigned upload preset".
# Cloud name = aparece en tu Dashboard de Cloudinary.
# Upload preset = Settings -> Upload -> Upload presets (Signing Mode: Unsigned).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
