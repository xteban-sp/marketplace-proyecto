{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Marketplace · Microservicios",
  "uid": "marketplace-ms",
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(up, service)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Servicios UP",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CAÍDO", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [ { "expr": "up{service=~\"$service\"}", "legendFormat": "{{service}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Peticiones HTTP por segundo",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        { "expr": "sum by (service) (rate(http_server_requests_seconds_count{service=~\"$service\"}[1m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latencia media HTTP (s)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (service) (rate(http_server_requests_seconds_sum{service=~\"$service\"}[1m])) / sum by (service) (rate(http_server_requests_seconds_count{service=~\"$service\"}[1m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memoria JVM usada (MB)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (service) (jvm_memory_used_bytes{service=~\"$service\", area=\"heap\"}) / 1024 / 1024", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errores HTTP 5xx por segundo",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum by (service) (rate(http_server_requests_seconds_count{service=~\"$service\", status=~\"5..\"}[1m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hilos vivos JVM",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "jvm_threads_live_threads{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ]
    }
  ]
}
